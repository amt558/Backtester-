__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/

# Virtual environments
venv/
.venv/
.venv-*/
env/

# IDE
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/

# Generated reports — don't commit these, they're outputs
reports/*.html
reports/*.png

# Cache
.cache/
.mypy_cache/
.pytest_cache/

# Audit trail DB — personal history, don't commit
data/

# Per-run smoke/report directories (auto-generated)
reports/*_2026-*/
reports/*_2027-*/
reports/*_2028-*/
reports/s2_pocket_pivot_*/
reports/rand_canary_*/
reports/leak_canary_*/
reports/overfit_canary_*/
reports/survivor_canary_*/

# Phase verification run outputs (auto-generated)
reports/_*/

# Session pytest capture files
pytest_full_output.txt
pytest_phase0_output.txt

# Logs
*.log

# Claude Code runtime (worktrees, session state)
.claude/

# OS
.DS_Store
Thumbs.db

# Secrets / local config overrides
tradelab.local.yaml
.env
*.key

# Live webhook runtime data (card registry + alert log)
# NOTE: code lives at src/tradelab/live/ (tracked); runtime state at /live/ (not tracked)
/live/*.json
/live/*.jsonl

# scratch/temp files at REPO ROOT only — the leading slash prevents the
# rule from shadowing nested __init__.py / _theme.py / _live.py etc.
/_*.py
/_*.txt
.worktrees/
.superpowers/
